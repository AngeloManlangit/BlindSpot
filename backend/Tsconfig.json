
{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "CommonJS",
    "moduleResolution": "node",
    "outDir":          "./dist",
    "rootDir":         "./",
    "strict":          true,
    "esModuleInterop": true,
    "skipLibCheck":    true,
    "resolveJsonModule": true
  },
  "include": ["index.ts", "services/**/*", "type/**/*"],
  "exclude": ["node_modules", "dist"]
}